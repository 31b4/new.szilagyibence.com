---
---

<section id="s-mission" style="position: absolute; inset: 0; will-change: transform, opacity; transform: translateY(100vh); opacity: 0;">

  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle farthest-corner at 50% 50%, rgba(8,14,36,1) 0%, rgba(5,10,26,1) 40%, rgba(2,4,12,1) 75%, rgba(0,0,0,1) 100%);"></div>

  <div class="mission-orb absolute w-[70vmax] h-[70vmax] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(18,40,110,0.35) 0%, transparent 70%); left: 50%; top: 50%; transform: translate(-50%, -50%);"></div>

  <div class="absolute top-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
  <div class="absolute bottom-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="relative z-10 w-full h-full flex items-center justify-center px-6 md:px-16">
    <div class="max-w-3xl w-full">

      <div class="m-reveal flex items-center gap-4 mb-10 md:mb-14">
        <div class="w-8 h-px bg-white/40"></div>
        <span class="text-xs font-medium tracking-[0.3em] uppercase text-white/50">The Mission</span>
      </div>

      <p class="m-reveal text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.12] mb-10 md:mb-14" style="font-family: 'Montserrat', sans-serif; letter-spacing: -0.01em;">
        Making health data<br/>
        <span style="color: rgba(255,255,255,0.35);">accessible</span> &amp; <span style="color: rgba(255,255,255,0.35);">understandable</span><br/>
        for everyone.
      </p>

      <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl mb-6">
        I believe every person deserves to understand their own body. I build tools that turn complex health information into clear, actionable insights.
      </p>
      <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl">
        Data should not be locked behind jargon — it should empower better decisions, every single day.
      </p>

      <div class="m-reveal mt-12 flex items-center gap-3">
        <div class="w-1.5 h-1.5 rounded-full bg-white/25"></div>
        <div class="w-12 h-px bg-white/15"></div>
        <div class="w-1 h-1 rounded-full bg-white/10"></div>
      </div>

    </div>
  </div>

</section>
