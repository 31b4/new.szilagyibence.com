---
import Layout from "../layouts/Layout.astro";
---

<Layout title="31b4 — Szilagyi Bence">

  <!-- FIXED HEADER -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 md:px-12 py-6">
    <div class="flex items-center gap-3">
      <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="20" cy="20" rx="18" ry="7" stroke="white" stroke-width="0.8" fill="none" opacity="0.3"/>
        <ellipse cx="20" cy="20" rx="15" ry="5.5" stroke="white" stroke-width="0.8" fill="none" opacity="0.5"/>
        <ellipse cx="20" cy="20" rx="12" ry="4" stroke="white" stroke-width="1" fill="none" opacity="0.7"/>
        <circle cx="20" cy="20" r="6" fill="black" stroke="white" stroke-width="1.2"/>
        <path d="M8 20 C8 12, 20 6, 20 6" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M32 20 C32 12, 20 6, 20 6" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M8 20 C8 28, 20 34, 20 34" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M32 20 C32 28, 20 34, 20 34" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <circle cx="20" cy="20" r="8" stroke="white" stroke-width="0.5" fill="none" opacity="0.25"/>
      </svg>
      <span class="text-sm font-bold tracking-[0.2em] uppercase">31b4</span>
    </div>
    <nav class="hidden md:flex items-center gap-8">
      <a href="#" data-go="0" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Home</a>
      <a href="#" data-go="1" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Mission</a>
      <a href="#" data-go="2" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Experience</a>
      <a href="#" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Contact</a>
    </nav>
  </header>

  <!-- FIXED FOOTER -->
  <footer class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-between px-8 md:px-12 py-6">
    <div class="flex items-center gap-5">
      <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="X (Twitter)">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
      <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.454C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
    <div class="flex items-center gap-3">
      <a href="#" class="text-sm font-medium text-white/60 hover:text-white transition-colors">Contact me</a>
      <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 1l2.09 6.26L22 9l-5.91 3.74L18.18 19 12 15.27 5.82 19l2.09-6.26L2 9l7.91-1.74z"/>
      </svg>
    </div>
  </footer>

  <!-- SECTION DOTS (right side) -->
  <div class="hidden lg:flex fixed right-8 top-1/2 -translate-y-1/2 z-50 flex-col gap-3">
    <button class="section-dot w-2 h-2 rounded-full bg-white" data-go="0" aria-label="Hero"></button>
    <button class="section-dot w-2 h-2 rounded-full bg-white/30" data-go="1" aria-label="Mission"></button>
    <button class="section-dot w-2 h-2 rounded-full bg-white/30" data-go="2" aria-label="Experience"></button>
  </div>

  <!-- Scroll hint (left side) -->
  <div class="hidden lg:flex fixed left-6 top-1/2 -translate-y-1/2 flex-col items-center gap-3 z-50" id="scroll-hint">
    <span class="text-[10px] font-medium tracking-[0.25em] uppercase text-white/40" style="writing-mode: vertical-rl;">Scroll</span>
    <svg class="w-3 h-3 text-white/40 mt-1" viewBox="0 0 12 12" fill="none">
      <path d="M6 1 L6 11 M2 7 L6 11 L10 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- FULLPAGE CONTAINER -->
  <div id="fullpage" style="position: fixed; inset: 0; overflow: hidden;">

    <!-- SECTION 0: HERO -->
    <section id="s-hero" style="position: absolute; inset: 0; will-change: transform, opacity;">

      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle farthest-corner at 50% 50%, rgba(22,38,88,1) 0%, rgba(18,32,74,1) 28%, rgba(13,24,57,1) 50%, rgba(9,16,40,1) 68%, rgba(5,9,24,1) 82%, rgba(2,4,11,1) 93%, rgba(0,0,0,1) 100%);"></div>

      <div class="relative z-10 w-full h-full flex items-center justify-center px-8 md:px-16">

        <!-- DESKTOP -->
        <div class="hidden lg:grid w-full max-w-5xl grid-cols-[1fr_auto_1fr] items-center gap-6 md:gap-10">
          <div class="relative flex flex-col items-start justify-center text-left -translate-y-20">
            <h1 class="relative z-10 text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Szilagyi<br />Bence
            </h1>
            <img src="/moon.png" alt="Moon" class="parallax-moon absolute w-16 md:w-20 lg:w-24 xl:w-28 aspect-square object-cover" style="border-radius: 50%; bottom: -5.5rem; left: 1rem; z-index: 20;"/>
          </div>

          <div class="relative flex items-center justify-center w-64 md:w-80 lg:w-96 xl:w-[28rem] aspect-square">
            <img src="/earth.png" alt="Earth from space" class="w-full h-full object-contain"/>
          </div>

          <div class="relative flex flex-col items-end justify-center text-right -translate-y-20">
            <img src="/neptune.png" alt="Neptune" class="parallax-neptune absolute w-16 md:w-20 lg:w-24 xl:w-28 object-contain" style="top: -5.2rem; right: -0.5rem; z-index: 20;"/>
            <h1 class="relative z-10 text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Building<br />Health
            </h1>
          </div>
        </div>

        <!-- MOBILE -->
        <div class="lg:hidden relative w-full flex items-center justify-center" style="min-height: 70vh;">
          <div class="relative w-56 sm:w-72 md:w-80 aspect-square">
            <img src="/earth.png" alt="Earth from space" class="w-full h-full object-contain"/>
          </div>
          <div class="absolute top-8 left-0 flex flex-col items-start">
            <h1 class="relative z-10 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Szilagyi<br />Bence
            </h1>
            <img src="/moon.png" alt="Moon" class="parallax-moon absolute w-20 sm:w-24 md:w-28 aspect-square object-cover" style="border-radius: 50%; bottom: -4rem; left: 0.5rem; z-index: 20;"/>
          </div>
          <div class="absolute bottom-8 right-0 flex flex-col items-end text-right">
            <img src="/neptune.png" alt="Neptune" class="parallax-neptune absolute w-20 sm:w-24 md:w-28 object-contain" style="top: -3.9rem; right: -0.8rem; z-index: 20;"/>
            <h1 class="relative z-10 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Building<br />Health
            </h1>
          </div>
        </div>

      </div>
    </section>

    <!-- SECTION 1: MISSION -->
    <section id="s-mission" style="position: absolute; inset: 0; will-change: transform, opacity; transform: translateY(100vh); opacity: 0;">

      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle farthest-corner at 50% 50%, rgba(8,14,36,1) 0%, rgba(5,10,26,1) 40%, rgba(2,4,12,1) 75%, rgba(0,0,0,1) 100%);"></div>

      <div class="mission-orb absolute w-[70vmax] h-[70vmax] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(18,40,110,0.35) 0%, transparent 70%); left: 50%; top: 50%; transform: translate(-50%, -50%);"></div>

      <div class="absolute top-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
      <div class="absolute bottom-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <div class="relative z-10 w-full h-full flex items-center justify-center px-6 md:px-16">
        <div class="max-w-3xl w-full">

          <div class="m-reveal flex items-center gap-4 mb-10 md:mb-14">
            <div class="w-8 h-px bg-white/40"></div>
            <span class="text-xs font-medium tracking-[0.3em] uppercase text-white/50">The Mission</span>
          </div>

          <p class="m-reveal text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.12] mb-10 md:mb-14" style="font-family: 'Montserrat', sans-serif; letter-spacing: -0.01em;">
            Making health data<br/>
            <span style="color: rgba(255,255,255,0.35);">accessible</span> &amp; <span style="color: rgba(255,255,255,0.35);">understandable</span><br/>
            for everyone.
          </p>

          <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl mb-6">
            I believe every person deserves to understand their own body. I build tools that turn complex health information into clear, actionable insights.
          </p>
          <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl">
            Data should not be locked behind jargon — it should empower better decisions, every single day.
          </p>

          <div class="m-reveal mt-12 flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-white/25"></div>
            <div class="w-12 h-px bg-white/15"></div>
            <div class="w-1 h-1 rounded-full bg-white/10"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 2: EXPERIENCE -->
    <section id="s-experience" style="position: absolute; inset: 0; will-change: transform, opacity; transform: translateY(100vh); opacity: 0; overflow-y: auto; background: radial-gradient(circle farthest-corner at 50% 0%, rgba(6,12,32,1) 0%, rgba(3,6,18,1) 40%, rgba(0,0,0,1) 80%);">

      <div class="relative z-10 min-h-screen">

        <!-- Spacer for fixed header -->
        <div class="h-24"></div>

        <!-- Section header -->
        <div class="max-w-5xl mx-auto px-6 md:px-16 pt-12 pb-16">
          <div class="exp-reveal flex items-center gap-4 mb-6">
            <div class="w-8 h-px bg-white/40"></div>
            <span class="text-xs font-medium tracking-[0.3em] uppercase text-white/50">Experience</span>
          </div>
          <h2 class="exp-reveal text-3xl sm:text-4xl md:text-5xl font-bold leading-[1.1]" style="font-family: 'Montserrat', sans-serif;">
            Where I've built things
          </h2>
        </div>

        <!-- ════ JOB 1: SONRISA (featured) ════ -->
        <div class="max-w-5xl mx-auto px-6 md:px-16 mb-20 md:mb-32">
          <div class="exp-reveal relative rounded-2xl border border-white/10 overflow-hidden" style="background: linear-gradient(135deg, rgba(15,25,60,0.6) 0%, rgba(8,14,36,0.4) 100%);">

            <!-- Glow accent -->
            <div class="absolute -top-20 -right-20 w-60 h-60 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(60,100,255,0.12) 0%, transparent 70%);"></div>

            <div class="relative z-10 p-8 md:p-12 lg:p-16">

              <!-- Top row: badge + dates -->
              <div class="flex flex-wrap items-center gap-3 mb-6">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold tracking-wider uppercase bg-indigo-500/20 text-indigo-300 border border-indigo-400/20">
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
                  Current
                </span>
                <span class="text-sm text-white/40">2025 — Present</span>
              </div>

              <!-- Company + Role -->
              <div class="flex flex-col md:flex-row md:items-end gap-4 md:gap-8 mb-8">
                <div class="flex items-center gap-4">
                  <!-- Placeholder logo -->
                  <div class="w-14 h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-7 h-7 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5l-1.341 4.022a2.25 2.25 0 01-2.134 1.528H8.475a2.25 2.25 0 01-2.134-1.528L5 14.5m14 0H5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-2xl md:text-3xl font-bold" style="font-family: 'Montserrat', sans-serif;">Sonrisa</h3>
                    <p class="text-white/50 text-sm mt-0.5">AI Software Engineer</p>
                  </div>
                </div>
              </div>

              <!-- Description -->
              <p class="text-white/55 text-base md:text-lg leading-relaxed max-w-2xl mb-10">
                Building AI agents and orchestrating sub-agent workflows. Designing intelligent agent tours, automating complex backend pipelines, and creating scalable agent architectures.
              </p>

              <!-- What I do -->
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
                <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-5">
                  <div class="w-8 h-8 rounded-lg bg-indigo-500/15 flex items-center justify-center mb-3">
                    <svg class="w-4 h-4 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <h4 class="text-sm font-semibold mb-1">Agent Workflows</h4>
                  <p class="text-xs text-white/40 leading-relaxed">Designing and building multi-step AI agent pipelines</p>
                </div>
                <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-5">
                  <div class="w-8 h-8 rounded-lg bg-indigo-500/15 flex items-center justify-center mb-3">
                    <svg class="w-4 h-4 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7z" stroke-linecap="round"/><path d="M12 8v8m-4-4h8" stroke-linecap="round"/></svg>
                  </div>
                  <h4 class="text-sm font-semibold mb-1">Sub-Agent Architecture</h4>
                  <p class="text-xs text-white/40 leading-relaxed">Creating hierarchical agent systems with sub-agent tours</p>
                </div>
                <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-5">
                  <div class="w-8 h-8 rounded-lg bg-indigo-500/15 flex items-center justify-center mb-3">
                    <svg class="w-4 h-4 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <h4 class="text-sm font-semibold mb-1">Backend Systems</h4>
                  <p class="text-xs text-white/40 leading-relaxed">Scalable backend infrastructure for AI-driven products</p>
                </div>
              </div>

              <!-- Tech stack -->
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">Python</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">LLMs</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">AI Agents</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">FastAPI</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">Docker</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">MinIO</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">Redis</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">Temporal.io</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.08] text-xs font-medium text-white/60">Langfuse</span>
              </div>

            </div>
          </div>
        </div>

        <!-- ════ JOB 2: ORTHOGRAPH (compact) ════ -->
        <div class="max-w-5xl mx-auto px-6 md:px-16 mb-20">
          <div class="exp-reveal relative rounded-xl border border-white/10 p-6 md:p-8" style="background: rgba(14,20,46,0.7);">

            <div class="flex flex-col sm:flex-row sm:items-start gap-4 sm:gap-6">
              <!-- Placeholder logo -->
              <div class="w-11 h-11 rounded-lg bg-white/8 border border-white/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-3 mb-1">
                  <h3 class="text-lg font-bold text-white/85" style="font-family: 'Montserrat', sans-serif;">OrthoGraph</h3>
                  <span class="text-xs text-white/45">2024 — 2025</span>
                </div>
                <p class="text-sm text-white/55">Fullstack Developer · Remote</p>
                <p class="text-sm text-white/45 mt-2 leading-relaxed">Maintained a Laravel-based backend and containerized it with Docker.</p>

                <div class="flex flex-wrap gap-1.5 mt-4">
                  <span class="px-2 py-1 rounded-md bg-white/[0.07] border border-white/[0.1] text-[11px] font-medium text-white/55">PHP</span>
                  <span class="px-2 py-1 rounded-md bg-white/[0.07] border border-white/[0.1] text-[11px] font-medium text-white/55">Laravel</span>
                  <span class="px-2 py-1 rounded-md bg-white/[0.07] border border-white/[0.1] text-[11px] font-medium text-white/55">Docker</span>
                  <span class="px-2 py-1 rounded-md bg-white/[0.07] border border-white/[0.1] text-[11px] font-medium text-white/55">Git</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Bottom spacer -->
        <div class="h-32"></div>

      </div>
    </section>

  </div>

  <script>
    const sections = [
      document.getElementById('s-hero'),
      document.getElementById('s-mission'),
      document.getElementById('s-experience'),
    ];

    const expSection = sections[2];
    const dots = document.querySelectorAll('.section-dot');
    const scrollHint = document.getElementById('scroll-hint');
    const siteFooter = document.querySelector('footer');

    let current = 0;
    let busy = false;
    const DURATION = 900;
    const EASE = 'cubic-bezier(0.76, 0, 0.24, 1)';

    function setTrans(el, dur) {
      el.style.transition = 'transform ' + dur + 'ms ' + EASE + ', opacity ' + dur + 'ms ' + EASE;
    }
    function clearTrans(el) {
      el.style.transition = 'none';
    }

    function updateDots(idx) {
      dots.forEach(function(d, i) {
        if (i === idx) {
          d.style.opacity = '0.9';
          d.style.background = 'white';
          d.style.transform = 'scale(1.4)';
        } else {
          d.style.opacity = '0.3';
          d.style.background = 'rgba(255,255,255,0.4)';
          d.style.transform = 'scale(1)';
        }
      });
      if (scrollHint) scrollHint.style.opacity = idx === 0 ? '1' : '0';
      // hide footer on experience (it scrolls with content)
      if (siteFooter) siteFooter.style.opacity = idx === 2 ? '0' : '1';
    }

    function triggerMissionReveals() {
      const els = document.querySelectorAll('.m-reveal');
      els.forEach(function(el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(36px)';
        el.style.transition = 'none';
      });
      els.forEach(function(el, i) {
        setTimeout(function() {
          el.style.transition = 'opacity 0.85s ' + EASE + ', transform 0.85s ' + EASE;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 80 + i * 140);
      });
      var orb = document.querySelector('.mission-orb');
      if (orb) {
        orb.style.transition = 'transform 2s ' + EASE;
        orb.style.transform = 'translate(-50%, -52%)';
      }
    }

    function resetMissionReveals() {
      var els = document.querySelectorAll('.m-reveal');
      els.forEach(function(el) {
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(36px)';
      });
      var orb = document.querySelector('.mission-orb');
      if (orb) {
        orb.style.transition = 'none';
        orb.style.transform = 'translate(-50%, -50%)';
      }
    }

    function triggerExpReveals() {
      var els = document.querySelectorAll('.exp-reveal');
      els.forEach(function(el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(40px)';
        el.style.transition = 'none';
      });
      els.forEach(function(el, i) {
        setTimeout(function() {
          el.style.transition = 'opacity 0.85s ' + EASE + ', transform 0.85s ' + EASE;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 350 + i * 150);
      });
    }

    function resetExpReveals() {
      var els = document.querySelectorAll('.exp-reveal');
      els.forEach(function(el) {
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(40px)';
      });
      // scroll back to top
      if (expSection) expSection.scrollTop = 0;
    }

    var PARALLAX_TRANS = 'transform ' + DURATION + 'ms ' + EASE;

    function setParallax(moonY, neptuneY, animate) {
      document.querySelectorAll('.parallax-moon').forEach(function(el) {
        el.style.transition = animate ? PARALLAX_TRANS : 'none';
        el.style.transform = moonY === 0 ? 'none' : 'translateY(' + moonY + 'px)';
      });
      document.querySelectorAll('.parallax-neptune').forEach(function(el) {
        el.style.transition = animate ? PARALLAX_TRANS : 'none';
        el.style.transform = neptuneY === 0 ? 'none' : 'translateY(' + neptuneY + 'px)';
      });
    }

    function goTo(next) {
      if (busy || next === current || next < 0 || next >= sections.length) return;
      busy = true;
      var prev = current;
      var dir = next > prev ? 1 : -1;
      current = next;

      // Lock experience section scroll during transition to prevent momentum bleed
      if (next === 2) expSection.style.overflowY = 'hidden';

      setTrans(sections[prev], DURATION);
      if (dir === 1) {
        sections[prev].style.transform = 'scale(0.92) translateY(-3%)';
        sections[prev].style.opacity = '0';
        if (prev === 0) setParallax(-55, 55, true);
      } else {
        sections[prev].style.transform = 'translateY(100vh)';
        sections[prev].style.opacity = '0';
        if (next === 0) setParallax(-55, 55, false);
      }

      clearTrans(sections[next]);
      sections[next].style.opacity = '0';
      if (dir === 1) {
        sections[next].style.transform = 'translateY(60px)';
      } else {
        sections[next].style.transform = 'scale(0.92) translateY(-3%)';
      }

      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          setTrans(sections[next], DURATION);
          sections[next].style.transform = 'none';
          sections[next].style.opacity = '1';

          if (dir === -1 && next === 0) setParallax(0, 0, true);

          // Trigger entering section's content reveals
          if (next === 1) triggerMissionReveals();
          if (next === 2) { triggerExpReveals(); topMomentumCooldown = false; }

          updateDots(next);

          // Reset the PREVIOUS section's content only after it has fully exited
          setTimeout(function() {
            if (prev === 1) resetMissionReveals();
            if (prev === 2) resetExpReveals();
            // Restore experience scroll and add a short cooldown to swallow tail momentum
            if (next === 2) expSection.style.overflowY = 'auto';
            busy = false;
            wheelAcc = 0;
            cooldown = true;
            setTimeout(function() { cooldown = false; }, 350);
          }, DURATION + 100);
        });
      });
    }

    updateDots(0);
    resetMissionReveals();
    resetExpReveals();

    // ─── Cooldown after momentum carries expSection to scrollTop=0 ───
    var topMomentumCooldown = false;
    var topMomentumTimer = null;
    expSection.addEventListener('scroll', function() {
      if (expSection.scrollTop > 0) {
        // mid-scroll: clear any lingering cooldown so a fresh stop-at-top arms it fresh
        clearTimeout(topMomentumTimer);
        topMomentumCooldown = false;
      } else {
        // just hit the top — arm cooldown to swallow momentum tail
        topMomentumCooldown = true;
        clearTimeout(topMomentumTimer);
        topMomentumTimer = setTimeout(function() { topMomentumCooldown = false; }, 450);
      }
    });

    // ─── Wheel handler with scroll-unlock for experience section ───
    var wheelAcc = 0;
    var wheelTimer = null;
    var cooldown = false;
    window.addEventListener('wheel', function(e) {
      if (current === 2) {
        var el = expSection;
        var atTop = el.scrollTop <= 0;
        var atBottom = el.scrollTop + el.clientHeight >= el.scrollHeight - 2;

        if (e.deltaY > 0) {
          if (atBottom) { e.preventDefault(); return; }
          return; // let native scroll happen
        }

        // Scrolling up
        if (!atTop) return; // still mid-content, let it scroll naturally

        // At top — only exit if not in momentum cooldown
        e.preventDefault();
        if (!topMomentumCooldown) goTo(current - 1);
        return;
      }

      e.preventDefault();
      if (cooldown) return; // swallow tail momentum after a transition
      wheelAcc += e.deltaY;
      if (wheelTimer) clearTimeout(wheelTimer);
      wheelTimer = setTimeout(function() { wheelAcc = 0; }, 200);
      if (Math.abs(wheelAcc) > 40) {
        goTo(wheelAcc > 0 ? current + 1 : current - 1);
        wheelAcc = 0;
      }
    }, { passive: false });

    window.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        if (current !== 2) goTo(current + 1);
      }
      if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        if (current === 2 && expSection.scrollTop <= 0) goTo(current - 1);
        else if (current !== 2) goTo(current - 1);
      }
    });

    var touchY = 0;
    window.addEventListener('touchstart', function(e) { touchY = e.touches[0].clientY; }, { passive: true });
    window.addEventListener('touchend', function(e) {
      var dy = touchY - e.changedTouches[0].clientY;
      if (current === 2) {
        if (dy > 50) return; // scrolling down, let native
        if (dy < -50 && expSection.scrollTop <= 0) goTo(current - 1);
        return;
      }
      if (Math.abs(dy) > 50) goTo(dy > 0 ? current + 1 : current - 1);
    }, { passive: true });

    document.querySelectorAll('[data-go]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        goTo(Number(el.dataset.go));
      });
    });
  </script>

  <style>
    html, body { background: #000; }
    body { overflow: hidden; }
    .m-reveal { opacity: 0; transform: translateY(36px); }
    .exp-reveal { opacity: 0; transform: translateY(40px); }
    #scroll-hint { transition: opacity 0.5s ease; }
    .section-dot { transition: opacity 0.3s ease, transform 0.3s ease, background 0.3s ease; }
    footer { transition: opacity 0.4s ease; }
  </style>

</Layout>
