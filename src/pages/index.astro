---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import HeroSection from "../components/HeroSection.astro";
import MissionSection from "../components/MissionSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import WorkSection from "../components/WorkSection.astro";
import ContactSection from "../components/ContactSection.astro";
---

<Layout title="31b4 — Szilagyi Bence">

  <SiteHeader />

  <!-- ── Normal document flow ── -->
  <HeroSection />
  <MissionSection />

  <!-- Projects + Work + Contact -->
  <section id="s-scroll" style="background: radial-gradient(ellipse 120% 60% at 50% 0%, rgba(10,18,48,1) 0%, rgba(4,8,22,1) 40%, rgba(0,0,0,1) 80%);">
    <ProjectsSection />
    <WorkSection />
    <ContactSection />
  </section>

  <script>
    import Lenis from 'lenis';
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // ── Viewport height util ──
    function setAppViewportHeight() {
      var h = window.visualViewport ? window.visualViewport.height : window.innerHeight;
      document.documentElement.style.setProperty('--app-vh', h + 'px');
    }
    setAppViewportHeight();
    window.addEventListener('resize', setAppViewportHeight);
    window.addEventListener('orientationchange', setAppViewportHeight);
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', setAppViewportHeight);
      window.visualViewport.addEventListener('scroll', setAppViewportHeight);
    }

    // ── Lenis smooth scroll (whole page) ──
    const lenis = new Lenis({
      smoothWheel: true,
      duration: 1.4,
      easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
    });
    function lenisRaf(time) { lenis.raf(time); requestAnimationFrame(lenisRaf); }
    requestAnimationFrame(lenisRaf);

    // Tell GSAP's ScrollTrigger about Lenis scroll position
    lenis.on('scroll', function() { ScrollTrigger.update(); });

    const EASE_STR = 'power2.out';

    // ── Hero: entrance animation on load ──
    gsap.fromTo('#s-hero .hero-content', { opacity: 0, y: 40 }, {
      opacity: 1, y: 0, duration: 1.1, ease: EASE_STR,
      stagger: 0.12, delay: 0.15,
    });

    // ── Hero exit + mission rise: hero stays pinned, scales back, fades away ──
    // Mission is animated in the same scrubbed timeline so it rises over hero
    // instead of waiting for hero to scroll off the page.
    gsap.timeline({
      scrollTrigger: {
        trigger: '#s-hero',
        start: 'top top',
        end: '+=85%',
        scrub: true,
        pin: true,
        pinSpacing: false,
      },
    })
      .to('#s-hero', {
        scale: 0.88,
        opacity: 0,
        ease: 'none',
      }, 0)
      .to('.parallax-moon', {
        y: -80,
        ease: 'none',
      }, 0)
      .to('.parallax-neptune', {
        y: 80,
        ease: 'none',
      }, 0)
      .fromTo('#s-mission', {
        y: '18vh',
        opacity: 0.18,
      }, {
        y: 0,
        opacity: 1,
        ease: 'none',
      }, 0);

    // ── Mission orb subtle rise ──
    gsap.to('.mission-orb', {
      y: -20,
      ease: 'none',
      scrollTrigger: {
        trigger: '#s-mission',
        start: 'top bottom',
        end: 'bottom top',
        scrub: true,
      },
    });

    // ── Mission content: staggered cascade as section scrolls into view ──
    var mRevealEls = Array.from(document.querySelectorAll('.m-reveal'));
    mRevealEls.forEach(function(el, i) {
      gsap.fromTo(el,
        { opacity: 0, y: 36 },
        {
          opacity: 1, y: 0,
          duration: 0.55,
          ease: EASE_STR,
          scrollTrigger: {
            trigger: el,
            start: 'top bottom',
            end: 'top 95%',
            toggleActions: 'play none none reverse',
          },
          delay: i * 0.04,
        }
      );
    });

    // ── Projects / Work / Contact: same early reveal pattern as Mission ──
    Array.from(document.querySelectorAll('.proj-reveal, .exp-reveal, .c-reveal, .proj-phone')).forEach(function(el, i) {
      var isPhone = el.classList.contains('proj-phone');

      gsap.fromTo(el,
        {
          opacity: 0,
          y: isPhone ? 60 : 36,
          scale: isPhone ? 0.92 : 1,
        },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.55,
          ease: EASE_STR,
          scrollTrigger: {
            trigger: el,
            start: 'top bottom',
            end: 'top 95%',
            toggleActions: 'play none none reverse',
          },
          delay: i * 0.04,
        }
      );
    });

    // ── Header glass-active when past hero ──
    var siteHeader = document.querySelector('.site-header');
    var siteFooter = document.querySelector('.site-footer');

    function syncMobileFooterVisibility(isPastHero) {
      if (!siteFooter) return;
      if (window.matchMedia('(max-width: 767px)').matches) {
        siteFooter.classList.toggle('mobile-hidden', isPastHero);
      } else {
        siteFooter.classList.remove('mobile-hidden');
      }
    }

    ScrollTrigger.create({
      trigger: '#s-mission',
      start: 'top 50%',
      onEnter: function() {
        if (siteHeader) siteHeader.classList.add('glass-active');
        syncMobileFooterVisibility(true);
      },
      onLeaveBack: function() {
        if (siteHeader) siteHeader.classList.remove('glass-active');
        syncMobileFooterVisibility(false);
      },
    });

    window.addEventListener('resize', function() {
      syncMobileFooterVisibility(Boolean(siteHeader && siteHeader.classList.contains('glass-active')));
    });

    // ── Scroll-hint: hide once user starts scrolling ──
    var scrollHint = document.getElementById('scroll-hint');
    if (scrollHint) {
      lenis.on('scroll', function(e) {
        if (e.scroll > 40) scrollHint.style.opacity = '0';
        else scrollHint.style.opacity = '1';
      });
    }

    // ── Navigation: data-go / data-anchor clicks ──
    var sectionAnchors = {
      0: '#s-hero',
      1: '#s-mission',
      2: '#anchor-projects',
    };
    document.querySelectorAll('[data-go]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.preventDefault();
        var targetIdx = Number(el.dataset.go);
        var anchor = el.dataset.anchor || null;
        var targetId = anchor ? ('#' + anchor) : (sectionAnchors[targetIdx] || '#s-hero');
        var targetEl = document.querySelector(targetId);
        if (targetEl) lenis.scrollTo(targetEl, { duration: 1.4 });
      });
    });

    // ── Section dots: highlight based on scroll position ──
    var dots = document.querySelectorAll('.section-dot');
    var dotSections = ['#s-hero', '#s-mission', '#anchor-projects'];
    dotSections.forEach(function(selector, i) {
      var triggerEl = document.querySelector(selector);
      if (!triggerEl) return;
      ScrollTrigger.create({
        trigger: triggerEl,
        start: 'top 50%',
        end: 'bottom 50%',
        onEnter: function() { setActiveDot(i); },
        onEnterBack: function() { setActiveDot(i); },
      });
    });

    function setActiveDot(idx) {
      dots.forEach(function(d, i) {
        if (i === idx) {
          d.style.opacity = '0.9';
          d.style.background = 'white';
          d.style.transform = 'scale(1.4)';
        } else {
          d.style.opacity = '0.3';
          d.style.background = 'rgba(255,255,255,0.4)';
          d.style.transform = 'scale(1)';
        }
      });
    }
    setActiveDot(0);

    // ── Float-next-btn: hide at bottom of page ──
    var floatNextBtn = document.getElementById('float-next-btn');
    if (floatNextBtn) {
      floatNextBtn.addEventListener('click', function() {
        var scrollY = window.scrollY;
        var vh = window.innerHeight;
        if (scrollY < vh * 0.5) {
          lenis.scrollTo('#s-mission', { duration: 1.4 });
        } else {
          lenis.scrollTo('#anchor-projects', { duration: 1.4 });
        }
      });
      ScrollTrigger.create({
        trigger: '#s-scroll',
        start: 'bottom 90%',
        onEnter: function() { floatNextBtn.style.opacity = '0'; floatNextBtn.style.pointerEvents = 'none'; },
        onLeaveBack: function() { floatNextBtn.style.opacity = '0.35'; floatNextBtn.style.pointerEvents = ''; },
      });
    }
  </script>

  <style>
    html, body { background: #000; }
    body { overflow-x: hidden; }

    :root {
      --hero-lift: clamp(1.5rem, 3vw, 2.75rem);
    }

    #s-hero {
      z-index: 1;
      transform-origin: center top;
      will-change: transform, opacity;
    }
    #s-mission,
    #s-scroll {
      position: relative;
      z-index: 2;
    }

    /* Initial hidden states for reveal classes */
    .m-reveal { opacity: 0; transform: translateY(36px); }
    .exp-reveal { opacity: 0; transform: translateY(40px); }
    .proj-reveal { opacity: 0; transform: translateY(40px); }
    .proj-phone { opacity: 0; transform: translateY(60px) scale(0.92); }
    .c-reveal { opacity: 0; transform: translateY(36px); }

    #scroll-hint { transition: opacity 0.5s ease; }

    /* Global scrollbar hide */
    html { scrollbar-width: none; -ms-overflow-style: none; }
    html::-webkit-scrollbar { display: none; }

    /* Floating next-section arrow */
    #float-next-btn {
      position: fixed; bottom: 1.75rem; left: 50%; transform: translateX(-50%);
      z-index: 50; background: transparent; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      padding: 0.75rem;
      opacity: 0.35; transition: opacity 0.5s ease;
    }
    #float-next-btn:hover { opacity: 0.8; }
    #float-next-btn svg { width: 1.5rem; height: 1.5rem; color: white; animation: arrowBob 2s ease-in-out infinite; }
    @keyframes arrowBob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }
  </style>

</Layout>
