---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import earthImg from '../assets/earth.png';
import moonImg from '../assets/moon.png';
import neptuneImg from '../assets/neptune.png';
import trackit1Img from '../assets/trackit1.png';
import trackit2Img from '../assets/trackit2.png';
import protocol1Img from '../assets/protocol1.png';
import protocol2Img from '../assets/protocol2.png';
import sonrisaImg from '../assets/sonrisa.png';
import orthographImg from '../assets/orthograph.png';
---

<Layout title="31b4 — Szilagyi Bence">

  <!-- FIXED HEADER -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 md:px-12 py-6">
    <a href="#" data-go="0" class="flex items-center gap-3" aria-label="Home">
      <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="20" cy="20" rx="18" ry="7" stroke="white" stroke-width="0.8" fill="none" opacity="0.3"/>
        <ellipse cx="20" cy="20" rx="15" ry="5.5" stroke="white" stroke-width="0.8" fill="none" opacity="0.5"/>
        <ellipse cx="20" cy="20" rx="12" ry="4" stroke="white" stroke-width="1" fill="none" opacity="0.7"/>
        <circle cx="20" cy="20" r="6" fill="black" stroke="white" stroke-width="1.2"/>
        <path d="M8 20 C8 12, 20 6, 20 6" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M32 20 C32 12, 20 6, 20 6" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M8 20 C8 28, 20 34, 20 34" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M32 20 C32 28, 20 34, 20 34" stroke="white" stroke-width="0.6" fill="none" opacity="0.4"/>
        <circle cx="20" cy="20" r="8" stroke="white" stroke-width="0.5" fill="none" opacity="0.25"/>
      </svg>
      <span class="text-sm font-bold tracking-[0.2em] uppercase">31b4</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="#" data-go="0" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Home</a>
      <a href="#" data-go="1" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Mission</a>
      <a href="#" data-go="2" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Projects</a>
      <a href="#" data-go="2" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Work</a>
      <a href="#" data-go="2" class="text-sm font-medium text-white/80 hover:text-white transition-colors">Contact</a>
    </nav>
  </header>

  <!-- FIXED FOOTER -->
  <footer class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-between px-8 md:px-12 py-6">
    <div class="flex items-center gap-5">
      <a href="https://x.com/31b4_" target="_blank" rel="noopener" class="text-white/60 hover:text-white transition-colors" aria-label="X (Twitter)">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://github.com/31b4" target="_blank" rel="noopener" class="text-white/60 hover:text-white transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/benszilagyi/" target="_blank" rel="noopener" class="text-white/60 hover:text-white transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.454C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
    <a href="#" data-go="2" class="text-sm font-medium text-white/60 hover:text-white transition-colors">Contact me</a>
  </footer>

  <!-- SECTION DOTS (right side) -->
  <div class="hidden lg:flex fixed right-8 top-1/2 -translate-y-1/2 z-50 flex-col gap-3">
    <button class="section-dot w-2 h-2 rounded-full bg-white" data-go="0" aria-label="Hero"></button>
    <button class="section-dot w-2 h-2 rounded-full bg-white/30" data-go="1" aria-label="Mission"></button>
    <button class="section-dot w-2 h-2 rounded-full bg-white/30" data-go="2" aria-label="Projects"></button>
  </div>

  <!-- Floating next-section arrow -->
  <button id="float-next-btn" aria-label="Go to next section">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 15l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <!-- Scroll hint (left side) -->
  <div class="hidden lg:flex fixed left-6 top-1/2 -translate-y-1/2 flex-col items-center gap-3 z-50" id="scroll-hint">
    <span class="text-[10px] font-medium tracking-[0.25em] uppercase text-white/40" style="writing-mode: vertical-rl;">Scroll</span>
    <svg class="w-3 h-3 text-white/40 mt-1" viewBox="0 0 12 12" fill="none">
      <path d="M6 1 L6 11 M2 7 L6 11 L10 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- FULLPAGE CONTAINER -->
  <div id="fullpage" style="position: fixed; inset: 0; overflow: hidden;">

    <!-- SECTION 0: HERO -->
    <section id="s-hero" style="position: absolute; inset: 0; will-change: transform, opacity;">

      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle farthest-corner at 50% 50%, rgba(22,38,88,1) 0%, rgba(18,32,74,1) 28%, rgba(13,24,57,1) 50%, rgba(9,16,40,1) 68%, rgba(5,9,24,1) 82%, rgba(2,4,11,1) 93%, rgba(0,0,0,1) 100%);"></div>

      <div class="relative z-10 w-full h-full flex items-center justify-center px-8 md:px-16">

        <!-- DESKTOP -->
        <div class="hidden lg:grid w-full max-w-5xl grid-cols-[1fr_auto_1fr] items-center gap-6 md:gap-10">
          <div class="relative flex flex-col items-start justify-center text-left -translate-y-20">
            <h1 class="relative z-10 text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Szilagyi<br />Bence
            </h1>
            <Image src={moonImg} alt="Moon" width={500} class="parallax-moon absolute w-16 md:w-20 lg:w-24 xl:w-28 aspect-square object-cover" style="border-radius: 50%; bottom: -5.5rem; left: 1rem; z-index: 20;" loading="eager"/>
          </div>

          <div class="relative flex items-center justify-center w-64 md:w-80 lg:w-96 xl:w-[28rem] aspect-square">
            <Image src={earthImg} alt="Earth from space" width={900} class="w-full h-full object-contain" loading="eager"/>
          </div>

          <div class="relative flex flex-col items-end justify-center text-right -translate-y-20">
            <Image src={neptuneImg} alt="Neptune" width={500} class="parallax-neptune absolute w-16 md:w-20 lg:w-24 xl:w-28 object-contain" style="top: -5.2rem; right: -0.5rem; z-index: 20;" loading="eager"/>
            <h1 class="relative z-10 text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Building<br />Health
            </h1>
          </div>
        </div>

        <!-- MOBILE -->
        <div class="lg:hidden relative w-full flex items-center justify-center" style="min-height: 70vh;">
          <div class="relative w-56 sm:w-72 md:w-80 aspect-square">
            <Image src={earthImg} alt="Earth from space" width={900} class="w-full h-full object-contain" loading="eager"/>
          </div>
          <div class="absolute top-8 left-0 flex flex-col items-start">
            <h1 class="relative z-10 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Szilagyi<br />Bence
            </h1>
            <Image src={moonImg} alt="Moon" width={500} class="parallax-moon absolute w-20 sm:w-24 md:w-28 aspect-square object-cover" style="border-radius: 50%; bottom: -4rem; left: 0.5rem; z-index: 20;" loading="eager"/>
          </div>
          <div class="absolute bottom-8 right-0 flex flex-col items-end text-right">
            <Image src={neptuneImg} alt="Neptune" width={500} class="parallax-neptune absolute w-20 sm:w-24 md:w-28 object-contain" style="top: -3.9rem; right: -0.8rem; z-index: 20;" loading="eager"/>
            <h1 class="relative z-10 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.05]" style="font-family: 'Montserrat', sans-serif; letter-spacing: 0.12em;">
              Building<br />Health
            </h1>
          </div>
        </div>

      </div>

    </section>

    <!-- SECTION 1: MISSION -->
    <section id="s-mission" style="position: absolute; inset: 0; will-change: transform, opacity; transform: translateY(100vh); opacity: 0;">

      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle farthest-corner at 50% 50%, rgba(8,14,36,1) 0%, rgba(5,10,26,1) 40%, rgba(2,4,12,1) 75%, rgba(0,0,0,1) 100%);"></div>

      <div class="mission-orb absolute w-[70vmax] h-[70vmax] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(18,40,110,0.35) 0%, transparent 70%); left: 50%; top: 50%; transform: translate(-50%, -50%);"></div>

      <div class="absolute top-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>
      <div class="absolute bottom-[18%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <div class="relative z-10 w-full h-full flex items-center justify-center px-6 md:px-16">
        <div class="max-w-3xl w-full">

          <div class="m-reveal flex items-center gap-4 mb-10 md:mb-14">
            <div class="w-8 h-px bg-white/40"></div>
            <span class="text-xs font-medium tracking-[0.3em] uppercase text-white/50">The Mission</span>
          </div>

          <p class="m-reveal text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.12] mb-10 md:mb-14" style="font-family: 'Montserrat', sans-serif; letter-spacing: -0.01em;">
            Making health data<br/>
            <span style="color: rgba(255,255,255,0.35);">accessible</span> &amp; <span style="color: rgba(255,255,255,0.35);">understandable</span><br/>
            for everyone.
          </p>

          <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl mb-6">
            I believe every person deserves to understand their own body. I build tools that turn complex health information into clear, actionable insights.
          </p>
          <p class="m-reveal text-base sm:text-lg text-white/45 leading-relaxed max-w-xl">
            Data should not be locked behind jargon — it should empower better decisions, every single day.
          </p>

          <div class="m-reveal mt-12 flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-white/25"></div>
            <div class="w-12 h-px bg-white/15"></div>
            <div class="w-1 h-1 rounded-full bg-white/10"></div>
          </div>

        </div>
      </div>

    </section>

    <!-- SECTION 2: SCROLL (Projects + Work + Contact) -->
    <section id="s-scroll" style="position: absolute; inset: 0; will-change: transform, opacity; transform: translateY(100vh); opacity: 0; overflow-y: hidden; background: radial-gradient(ellipse 120% 60% at 50% 0%, rgba(10,18,48,1) 0%, rgba(4,8,22,1) 40%, rgba(0,0,0,1) 80%);"><div id="s-scroll-content">

      <!-- ── Projects ── -->
      <div id="anchor-projects">
      <div class="relative z-10">

        <!-- Spacer for fixed header -->
        <div class="h-24"></div>

        <!-- Section header -->
        <div class="max-w-6xl mx-auto px-6 md:px-16 pt-12 pb-16">
          <div class="proj-reveal flex items-center gap-4 mb-6">
            <div class="w-8 h-px bg-white/40"></div>
            <span class="text-xs font-medium tracking-[0.3em] uppercase text-white/50">Projects</span>
          </div>
          <h2 class="proj-reveal text-3xl sm:text-4xl md:text-5xl font-bold leading-[1.1]" style="font-family: 'Montserrat', sans-serif;">
            What I've shipped
          </h2>
          <p class="proj-reveal text-base sm:text-lg text-white/40 mt-4 max-w-xl leading-relaxed">
            Tools that put health data in people's hands.
          </p>
        </div>

        <!-- ════ PROJECT 1: TRACKIT ════ -->
        <div class="max-w-6xl mx-auto px-6 md:px-16 mb-24 md:mb-36">
          <div class="proj-reveal relative rounded-2xl border border-white/[0.08] overflow-hidden" style="background: linear-gradient(160deg, rgba(12,22,55,0.5) 0%, rgba(6,12,30,0.3) 100%);">

            <!-- Subtle glow -->
            <div class="absolute -top-24 left-1/4 w-[400px] h-[250px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(50,120,255,0.08) 0%, transparent 70%);"></div>

            <div class="relative z-10 p-8 md:p-12 lg:p-16">

              <div class="flex flex-col lg:flex-row lg:items-start gap-10 lg:gap-16">

                <!-- Text side -->
                <div class="flex-1 min-w-0">

                  <!-- Badge -->
                  <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold tracking-wider uppercase bg-blue-500/15 text-blue-300 border border-blue-400/15">
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                      App Store
                    </span>
                    <span class="text-sm text-white/35">iOS</span>
                  </div>

                  <h3 class="text-2xl md:text-4xl font-bold mb-4" style="font-family: 'Montserrat', sans-serif;">
                    TrackIt
                  </h3>
                  <p class="text-white/50 text-base md:text-lg leading-relaxed max-w-xl mb-8">
                    Your body, your data. A privacy-first iOS app that turns body measurements into clear visual insights — syncing seamlessly with Apple Health so you always understand your progress.
                  </p>

                  <!-- Key features -->
                  <div class="space-y-4 mb-8">
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-lg bg-blue-500/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div>
                        <h4 class="text-sm font-semibold text-white/70">15+ Body Measurements</h4>
                        <p class="text-xs text-white/40 leading-relaxed">Track weight, body fat, BMI, circumferences — with auto-calculated metrics like lean body mass and FFMI.</p>
                      </div>
                    </div>
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-lg bg-blue-500/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div>
                        <h4 class="text-sm font-semibold text-white/70">Apple Health Sync</h4>
                        <p class="text-xs text-white/40 leading-relaxed">Bidirectional sync with Apple Health and Apple Watch. Background updates every 5 minutes.</p>
                      </div>
                    </div>
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-lg bg-blue-500/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="14" r="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div>
                        <h4 class="text-sm font-semibold text-white/70">Progress Photos</h4>
                        <p class="text-xs text-white/40 leading-relaxed">Capture and organize progress photos with side-by-side before/after comparisons.</p>
                      </div>
                    </div>
                    <div class="flex items-start gap-3">
                      <div class="w-7 h-7 rounded-lg bg-blue-500/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div>
                        <h4 class="text-sm font-semibold text-white/70">Privacy First</h4>
                        <p class="text-xs text-white/40 leading-relaxed">Local-first storage with optional encrypted cloud backup. Your data never leaves your device.</p>
                      </div>
                    </div>
                  </div>

                  <!-- Tech pills -->
                  <div class="flex flex-wrap gap-2">
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">Swift</span>
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">SwiftUI</span>
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">HealthKit</span>
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">SwiftData</span>
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">Charts</span>
                    <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07] text-xs font-medium text-white/50">CloudKit</span>
                  </div>

                </div>

                <!-- Phone mockups -->
                <div class="flex-shrink-0 flex items-start gap-4 md:gap-6 mx-auto lg:mx-0 lg:mt-8">
                  <div class="proj-phone w-[130px] sm:w-[160px] md:w-[190px] lg:w-[210px]">
                    <Image src={trackit1Img} alt="TrackIt dashboard showing body measurements" width={420} class="w-full h-auto rounded-[22px] md:rounded-[28px] shadow-2xl shadow-blue-950/40"/>
                  </div>
                  <div class="proj-phone w-[130px] sm:w-[160px] md:w-[190px] lg:w-[210px] mt-12 md:mt-16">
                    <Image src={trackit2Img} alt="TrackIt progress photos and analytics" width={420} class="w-full h-auto rounded-[22px] md:rounded-[28px] shadow-2xl shadow-blue-950/40"/>
                  </div>
                </div>

              </div>

            </div>
          </div>
        </div>

        <!-- ════ PROJECT 2: PROTOCOL ════ -->
        <div class="max-w-6xl mx-auto px-6 md:px-16 mb-20">
          <div class="proj-reveal relative rounded-2xl border border-white/[0.08] overflow-hidden" style="background: linear-gradient(160deg, rgba(10,20,48,0.5) 0%, rgba(5,10,28,0.3) 100%);">

            <!-- Subtle glow -->
