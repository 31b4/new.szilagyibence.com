---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "31b4 — Szilagyi Bence" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="DESIGNED STUDIO — Exquisite makes Moments better." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  :root {
    --app-vh: 100dvh;
  }
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100dvh;
    height: 100%;
    background: #000;
    overscroll-behavior: none;
  }
</style>
